{
  "name": "derekhuynen-mcp-server",
  "version": "1.0.0",
  "description": "A production-grade MCP server exposing Derek Huynen's public professional profile over stdio and Streamable HTTP.",
  "type": "module",
  "license": "MIT",
  "author": "Derek Huynen <derek.huynen@gmail.com>",
  "homepage": "https://github.com/derekhuynen/derekhuynen-mcp-server",
  "bin": {
    "derekhuynen-mcp-server": "dist/transports/stdio.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-data.mjs",
    "start:stdio": "node dist/transports/stdio.js",
    "start:http": "node dist/transports/http.js",
    "dev:stdio": "tsx src/transports/stdio.ts",
    "dev:http": "tsx src/transports/http.ts",
    "generate": "node scripts/generate-profile.mjs && prettier --write src/data/profile.json && tsx scripts/check-profile.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.2.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "gray-matter": "^4.0.3",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
